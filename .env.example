# Local secrets for terms-gated sources. Copy to `.env` (gitignored) and fill in.
# The Makefile auto-loads `.env` and exports these to ingest recipes, so
# `make warehouse` / `make refresh-live` pick up keyed sources with no extra flags.
# Keys are sent on the request only and never written to snapshots (fetch + the
# AA authed fetch both strip/omit credentials from what they persist).

# Artificial Analysis (https://artificialanalysis.ai) — Intelligence Index + per-eval scores + pricing
AA_OPT_IN=1
AA_API_KEY=

# llm-stats.com Data API (https://llm-stats.com/developer) — third-party aggregator
LLMSTATS_OPT_IN=1
LLMSTATS_API_KEY=

# Hugging Face token for gated official leaderboards (hf_official adapter)
HF_TOKEN=
